#include <iostream>
#include <vector>
#include <memory>
#include <cmath>
#include <cfloat>
#include <cuda_runtime.h>

#define CUDA_CHECK(x) if((x)!=cudaSuccess){ printf("CUDA Error\n"); exit(1); }

// ================= MATMUL =================
__global__ void matmul_kernel(
    const float* A, const float* B, float* C,
    int M, int N, int K)
{
    int row = blockIdx.y * blockDim.y + threadIdx.y;
    int col = blockIdx.x * blockDim.x + threadIdx.x;

    if (row < M && col < N)
    {
        float sum = 0.0f;
        for (int i = 0; i < K; i++)
            sum += A[row * K + i] * B[i * N + col];

        C[row * N + col] = sum;
    }
}

// ================= SOFTMAX =================
__global__ void softmax_kernel(const float* input, float* output, int cols)
{
    int tid = threadIdx.x;

    __shared__ float smax[256];
    __shared__ float ssum[256];

    float local_max = -FLT_MAX;
    for (int i = tid; i < cols; i += blockDim.x)
        local_max = fmaxf(local_max, input[i]);

    smax[tid] = local_max;
    __syncthreads();

    for (int offset = blockDim.x / 2; offset > 0; offset /= 2)
    {
        if (tid < offset)
            smax[tid] = fmaxf(smax[tid], smax[tid + offset]);
        __syncthreads();
    }

    float max_val = smax[0];

    float local_sum = 0.0f;
    for (int i = tid; i < cols; i += blockDim.x)
        local_sum += expf(input[i] - max_val);

    ssum[tid] = local_sum;
    __syncthreads();

    for (int offset = blockDim.x / 2; offset > 0; offset /= 2)
    {
        if (tid < offset)
            ssum[tid] += ssum[tid + offset];
        __syncthreads();
    }

    float sum_val = ssum[0];

    for (int i = tid; i < cols; i += blockDim.x)
        output[i] = expf(input[i] - max_val) / sum_val;
}

// ================= KV CACHE =================
class KVCache {
public:
    float* d_K;
    float* d_V;
    int max_len;
    int dim;
    int cur_len;

    KVCache(int max_len, int dim)
        : max_len(max_len), dim(dim), cur_len(0)
    {
        CUDA_CHECK(cudaMalloc(&d_K, max_len * dim * sizeof(float)));
        CUDA_CHECK(cudaMalloc(&d_V, max_len * dim * sizeof(float)));
    }

    void append(float* new_k, float* new_v)
    {
        CUDA_CHECK(cudaMemcpy(d_K + cur_len * dim, new_k,
                              dim * sizeof(float), cudaMemcpyDeviceToDevice));

        CUDA_CHECK(cudaMemcpy(d_V + cur_len * dim, new_v,
                              dim * sizeof(float), cudaMemcpyDeviceToDevice));

        cur_len++;
    }
};

// ================= MAIN =================
int main()
{
    int dim = 8;
    int max_len = 10;

    // fake weights
    float *Wq, *Wk, *Wv;
    CUDA_CHECK(cudaMalloc(&Wq, dim * dim * sizeof(float)));
    CUDA_CHECK(cudaMalloc(&Wk, dim * dim * sizeof(float)));
    CUDA_CHECK(cudaMalloc(&Wv, dim * dim * sizeof(float)));

    // input token (1xdim)
    float* d_input;
    CUDA_CHECK(cudaMalloc(&d_input, dim * sizeof(float)));

    KVCache cache(max_len, dim);

    float *Q, *K, *V;
    CUDA_CHECK(cudaMalloc(&Q, dim * sizeof(float)));
    CUDA_CHECK(cudaMalloc(&K, dim * sizeof(float)));
    CUDA_CHECK(cudaMalloc(&V, dim * sizeof(float)));

    float *scores, *weights, *output;
    CUDA_CHECK(cudaMalloc(&scores, max_len * sizeof(float)));
    CUDA_CHECK(cudaMalloc(&weights, max_len * sizeof(float)));
    CUDA_CHECK(cudaMalloc(&output, dim * sizeof(float)));

    for (int step = 0; step < 5; step++)
    {
        std::cout << "Step " << step << std::endl;

        // ==== Q, K, V ====
        matmul_kernel<<<1, dim>>>(d_input, Wq, Q, 1, dim, dim);
        matmul_kernel<<<1, dim>>>(d_input, Wk, K, 1, dim, dim);
        matmul_kernel<<<1, dim>>>(d_input, Wv, V, 1, dim, dim);

        cudaDeviceSynchronize();

        // ==== append to cache ====
        cache.append(K, V);

        // ==== attention: Q × K_cache^T ====
        matmul_kernel<<<1, max_len>>>(Q, cache.d_K, scores,
                                     1, cache.cur_len, dim);

        cudaDeviceSynchronize();

        // ==== softmax ====
        softmax_kernel<<<1, 256>>>(scores, weights, cache.cur_len);

        cudaDeviceSynchronize();

        // ==== weighted sum ====
        matmul_kernel<<<1, dim>>>(weights, cache.d_V, output,
                                 1, dim, cache.cur_len);

        cudaDeviceSynchronize();

        // ==== fake next token ====
        std::cout << "Generated token: " << rand() % 100 << std::endl;
    }

    return 0;
}
